{
  "name": "house-of-fire",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for House of Fire — mobile, web, tablet, admin, and the design system that powers them.",
  "packageManager": "pnpm@10.34.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:migrate": "node scripts/run-migrations.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "configure:auth-smtp": "node scripts/configure-supabase-auth-smtp.mjs",
    "verify:auth-smtp": "node scripts/verify-supabase-auth-smtp.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.27.9",
    "turbo": "^2.9.16",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.21.0"
  }
}
