# Staging environment overrides.
# Copy to `.env.staging` (gitignored) and fill in. Loaded AFTER .env/.env.local when
# scripts run with `--env staging` (e.g. `pnpm configure:auth-urls:staging`), so only
# put values here that differ from production.
#
# Get the staging values from the Supabase dashboard:
#   houseoffiresdb → branch "staging" → Connect (top bar) → App Frameworks / API keys.
# The staging branch has its OWN project ref and anon key — do NOT reuse production's.

# Supabase staging branch
NEXT_PUBLIC_SUPABASE_URL=https://<staging-branch-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-branch-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-branch-service-role-key>

# Staging app URL (Vercel staging project / custom domain)
NEXT_PUBLIC_APP_URL=https://staging.houseoffire.events

# Extra redirect URLs for the staging allow list (staging callbacks are added
# automatically from NEXT_PUBLIC_APP_URL by configure-supabase-auth-urls.mjs)
SUPABASE_AUTH_REDIRECT_URLS=http://localhost:3000/auth/callback/client,http://localhost:3000/auth/callback

# Resend — use a SEPARATE API key for staging so it can be rotated independently.
# Either send from a verified staging subdomain or use Resend test addresses.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# SUPABASE_ACCESS_TOKEN is account-level — keep it in .env.local, not here.
