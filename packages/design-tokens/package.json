{
  "name": "@hof/design-tokens",
  "version": "0.0.0",
  "description": "House of Fire design tokens — colors, type, spacing, radii, motion. TS exports + CSS custom properties.",
  "type": "module",
  "sideEffects": ["*.css"],
  "files": ["dist", "tokens.css"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tokens.css": "./tokens.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint .",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
