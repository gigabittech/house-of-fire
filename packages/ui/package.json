{
  "name": "@hof/ui",
  "version": "0.0.0",
  "description": "House of Fire component library — productionized primitives + feed atoms.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist .turbo storybook-static"
  },
  "dependencies": {
    "@hof/design-tokens": "workspace:*",
    "@zxing/browser": "^0.1.5"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19.0",
    "react-dom": "^18.3 || ^19.0"
  },
  "devDependencies": {
    "@storybook/react": "^9.0.18",
    "@storybook/react-vite": "^9.0.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^9.0.18",
    "typescript": "^5.9.0",
    "vite": "^6.4.0",
    "vitest": "^3.2.0"
  }
}
