{
  "$schema": "https://turbo.build/schema.json",
  "daemon": false,
  "globalDependencies": [".env.local", ".env.*.local", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "NODE_OPTIONS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": []
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
