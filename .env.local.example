# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret (production / optional local backup via `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — ticket/waitlist emails (app API routes) AND Supabase Auth SMTP sender/password.
# The domain in RESEND_FROM_EMAIL MUST be verified at https://resend.com/domains
# or Resend returns 500 "Error sending magic link email" from Supabase.
# Local dev: onboarding@resend.dev — production: you@your-verified-domain.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# One-time hosted setup: push auth config to Supabase (see package.json scripts)
# Token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (Supabase Auth → Authentication → Providers → Google)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated magic-link redirect URLs (local Supabase CLI + hosted allow list)
# Local `supabase start` reads these via config.toml — CLI uses `.env` (copy/symlink from `.env.local`)
# Production hosted setup: `pnpm configure:auth-urls` (uses NEXT_PUBLIC_APP_URL + this list)
SUPABASE_AUTH_REDIRECT_URLS=http://localhost:3000/auth/callback/client,http://localhost:3000/auth/callback

# Ticket QR signing (mobile; use a long random string in production)
QR_HMAC_SECRET=dev-secret-do-not-use-in-prod


NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=