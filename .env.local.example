# Copy to .env.local at the monorepo root (house-of-fire/.env.local).
# Both apps/mobile and apps/admin load env from here via next.config.ts.

# Supabase (shared — mobile + admin)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (mobile app only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret (production / optional local via `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (mobile app only)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=tickets@houseoffire.events

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Ticket QR signing (mobile; use a long random string in production)
QR_HMAC_SECRET=dev-secret-do-not-use-in-prod
