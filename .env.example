# Used by Supabase CLI (supabase/config.toml) when running `supabase start` locally.
# Also loaded by `pnpm configure:auth-smtp` if vars are not in apps/mobile/.env.local.

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=you@your-verified-domain.com

# One-time: configure hosted Supabase Auth SMTP via Management API
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...

# Optional overrides for configure-supabase-auth-smtp.mjs
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_SMTP_HOST=smtp.resend.com
# SUPABASE_SMTP_PORT=465
# SUPABASE_RATE_LIMIT_EMAIL_SENT=100
# SUPABASE_RATE_LIMIT_OTP=100
