# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret (production / optional local backup via `stripe listen`)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — ticket/waitlist emails (app API routes) AND Supabase Auth SMTP sender/password.
# The domain in RESEND_FROM_EMAIL MUST be verified at https://resend.com/domains
# or Resend returns 500 "Error sending magic link email" from Supabase.
# Local dev: onboarding@resend.dev — production: you@your-verified-domain.com
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev

# One-time hosted setup: push Resend SMTP to Supabase Auth (avoids "email rate limit exceeded")
# Token: https://supabase.com/dashboard/account/tokens — then: pnpm configure:auth-smtp
SUPABASE_ACCESS_TOKEN=sbp_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
